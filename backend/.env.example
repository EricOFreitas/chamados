# Ambiente
NODE_ENV=development
PORT=3001

# Banco de dados (PostgreSQL no Coolify)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/chamados?schema=public"

# JWT
JWT_SECRET=troque_por_segredo_forte_aqui
JWT_REFRESH_SECRET=troque_por_refresh_segredo_forte_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@exemplo.com
SMTP_PASS=suasenha
SMTP_FROM="Chamados Suporte <seuemail@exemplo.com>"

# E-mail do técnico (recebe notificações)
TECHNICIAN_EMAIL=tecnico@exemplo.com
TECHNICIAN_PHONE=5511999999999

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution.exemplo.com
EVOLUTION_API_TOKEN=seu_token_aqui
EVOLUTION_INSTANCE=nome_da_instancia

# URL do frontend (para links nos emails)
FRONTEND_URL=https://chamados.exemplo.com
